{
  "name": "lol-arena-tracker",
  "version": "1.0.8",
  "main": "dist-electron/main/index.js",
  "description": "Arena Tracker - Track your Arena God challenge progress in League of Legends",
  "author": "Crimsab",
  "homepage": "https://github.com/Crimsab/lol-arena-tracker",
  "repository": {
    "type": "git",
    "url": "git@github.com:Crimsab/lol-arena-tracker.git"
  },
  "private": true,
  "debug": {
    "env": {
      "VITE_DEV_SERVER_URL": "http://127.0.0.1:3344/"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "vite",
    "typecheck": "vue-tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "build": "vue-tsc --noEmit && vite build && electron-builder",
    "build:release": "vue-tsc --noEmit && vite build && electron-builder --publish never",
    "build:portable": "vue-tsc --noEmit && vite build && electron-builder --win portable",
    "build:installer": "vue-tsc --noEmit && vite build && electron-builder --win nsis",
    "preview": "vite preview"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.7",
    "electron": "39.8.5",
    "electron-builder": "^26.8.1",
    "typescript": "^5.9.3",
    "vite": "^8.0.14",
    "vite-plugin-electron": "^0.29.1",
    "vite-plugin-electron-renderer": "^0.14.7",
    "vitest": "^4.1.7",
    "vue": "^3.5.34",
    "vue-tsc": "^2.2.12"
  },
  "dependencies": {
    "@fortawesome/fontawesome-svg-core": "^6.7.2",
    "@fortawesome/free-brands-svg-icons": "^6.7.2",
    "@fortawesome/free-regular-svg-icons": "^6.7.2",
    "@fortawesome/free-solid-svg-icons": "^6.7.2",
    "@fortawesome/vue-fontawesome": "^3.2.0",
    "@types/ws": "^8.18.1",
    "electron-updater": "^6.6.2",
    "electron-store": "^10.1.0",
    "ws": "^8.20.1"
  }
}
